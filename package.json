{
  "name": "yaca-voice",
  "version": "2.1.2",
  "type": "module",
  "description": "YACA Voice Integration for FiveM & RedM",
  "author": "MineMalox & LuftigerLuca",
  "repository": {
    "type": "git",
    "url": "https://github.com/yaca-systems/fivem-yaca-typescript"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "typecheck": "turbo typecheck --env-mode=loose",
    "lint": "turbo lint --env-mode=loose",
    "build": "turbo build --env-mode=loose",
    "dev": "turbo dev --env-mode=loose",
    "create-resource": "turbo create-resource --env-mode=loose && node scripts/create-resource.js",
    "format": "prettier --write \"**/*.{mjs,cjs,js,ts,json,yml,yaml,md}\"",
    "ci:format": "prettier --check \"**/*.{mjs,cjs,js,ts,json,yml,yaml,md}\"",
    "ci:lint": "turbo ci:lint --env-mode=loose"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "eslint": "^9.11.1",
    "prettier": "^3.3.3",
    "turbo": "^2.1.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "esbuild": "^0.24.0"
  },
  "packageManager": "pnpm@9.12.1+sha512.e5a7e52a4183a02d5931057f7a0dbff9d5e9ce3161e33fa68ae392125b79282a8a8a470a51dfc8a0ed86221442eb2fb57019b0990ed24fab519bf0e1bc5ccfc4"
}
